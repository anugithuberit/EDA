import pandas as pd
import matplotlib.pyplot as plt
import numpy as np

# Read CSV File
df = pd.read_csv("weather.csv")

# Convert Date column to datetime
df['Date'] = pd.to_datetime(df['Date'])

# 1. Filter temperature above 35°C
high_temp = df[df['Temperature'] > 35]

print("Days where temperature is above 35°C:")
print(high_temp)

# 2. Handle missing humidity values using mean replacement
mean_humidity = df['Humidity'].mean()
df['Humidity'].fillna(mean_humidity, inplace=True)

print("\nDataset after replacing missing humidity values:")
print(df)

# 3. Plot Temperature Trend
plt.figure(figsize=(8,5))
plt.plot(df['Date'], df['Temperature'], marker='o', label='Temperature')
plt.title("Temperature Trend")
plt.xlabel("Date")
plt.ylabel("Temperature (°C)")
plt.legend()
plt.grid(True)
plt.show()

# 4. Plot Rainfall Trend
plt.figure(figsize=(8,5))
plt.plot(df['Date'], df['Rainfall'], marker='o', label='Rainfall')
plt.title("Rainfall Trend")
plt.xlabel("Date")
plt.ylabel("Rainfall (mm)")
plt.legend()
plt.grid(True)
plt.show()


